@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "code")]
    public string ProductCode { get; set; }

    private Product product = new Product();

    protected override async void OnParametersSet()
    {
        if (string.IsNullOrEmpty(ProductCode))
        {
            product = new Product();
        }
        else
        {
            product = await productManager.GetByCode(ProductCode);
            if (product == null)
                product = new Product();
        }
    }

    private void addImage()
    {

    }

    private async void changeProduct()
    {
        productManager.Insert(product);
        product = await productManager.GetByCode(product.Code); //dönüş değeri farklı olduğu için geçici
        if(selectedImage != "")
        {
            FirmDoc fd = new();
            fd.ProtuctId = product.Id;
            fd.LineNumber = 0;
            fd.LData = Encoding.ASCII.GetBytes(selectedImage);
            firmDocManager.Insert(fd);
        }
    }

    private List<string> imageUrls = new();
    private string selectedImage ="";

    private async Task HandleSelectedFiles(InputFileChangeEventArgs e)
    {
        using var stream = e.File.OpenReadStream(maxAllowedSize: 250_000);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        var base64 = Convert.ToBase64String(ms.ToArray());
        selectedImage = "data:image/jpeg;base64,"+ base64;
        imageUrls.Add(selectedImage);
    }



    private void SelectImage(string url)
    {
        selectedImage = url;
    }


}
