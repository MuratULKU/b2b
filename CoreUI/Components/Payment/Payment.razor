
<div class="container">
    <div class="row">

        <CreditCardPage OrderId="@OrderId" ClientCode="@ClientCode" />



    </div>


    <div class="row">
        <div class="col-md-6">
            <div class="box-body text-left">
                <img src="./media/secure.jpg" width="225px" />

            </div>
        </div>
        <div class="col-md-6">
            <div class="payment-footer">
                <div class="row">
                    <div class="col-md-3">
                        <a href="/infoguvenlik">Güvenlik ve Gizlilik</a>
                    </div>
                    <div class="col-md-3">
                        <a href="/infomesafeli">Mesafeli Sözleşmeler</a>
                    </div>
                    <div class="col-md-3">
                        <a href="/infoiade">Değişim ve İade Koşulları</a>
                    </div>
                    <div class="col-md-3">
                        <a href="/infokargo">Teslimat ve Kargo</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>



<div class="modal fade" id="payment-modal" data-backdrop="static" tabindex="-1" role="dialog" aria-labelledby="staticBackdrop" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-body">
                <iframe style="width:100%;height:600px;border:none" frameborder="0"></iframe>
            </div>
        </div>
    </div>
</div>

@code {

    [Parameter] public Guid OrderId { get; set; }
    
    [Parameter] public string ClientCode { get; set; }


  
}
