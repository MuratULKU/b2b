
@using Business.Concrete
@using CoreUI.Data
@using Entity
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Web

@inject ILogger<Login> _logger;
@inject AuthenticationStateProvider authStateProvider
@inject NavigationManager navManager
@inject UserManager _userManager
@inject UserRoleManager _userRoleManager

<style>
    .login-wrapper {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
        box-sizing: border-box;
    }

    .login-card {
        width: 100%;
        max-width: 420px;
        background: #ffffff;
        border-radius: 12px;
        box-shadow: 0 2px 16px rgba(0, 0, 0, 0.08);
        overflow: hidden;
    }

    .login-header {
        padding: 2rem 2rem 1.5rem;
        text-align: center;
        border-bottom: 1px solid #f0f0f0;
    }

    .login-icon {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: #e8f0fe;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1rem;
        font-size: 22px;
    }

    .login-header h2 {
        margin: 0 0 4px;
        font-size: 1.2rem;
        font-weight: 600;
        color: #1a1a1a;
    }

    .login-header p {
        margin: 0;
        font-size: 0.85rem;
        color: #888;
    }

    .login-body {
        padding: 1.75rem 2rem 2rem;
    }

    .form-group {
        margin-bottom: 1.25rem;
    }

        .form-group label {
            display: block;
            font-size: 0.82rem;
            font-weight: 500;
            color: #555;
            margin-bottom: 6px;
        }

        .form-group input {
            width: 100%;
            box-sizing: border-box;
            padding: 10px 14px;
            font-size: 0.9rem;
            border: 1px solid #ddd;
            border-radius: 8px;
            background: #fafafa;
            color: #1a1a1a;
            transition: border-color 0.2s, box-shadow 0.2s;
            outline: none;
        }

            .form-group input:focus {
                border-color: #4a90e2;
                box-shadow: 0 0 0 3px rgba(74, 144, 226, 0.15);
                background: #fff;
            }

    .error-message {
        background: #fff0f0;
        border: 1px solid #fcc;
        border-radius: 8px;
        padding: 10px 14px;
        color: #c0392b;
        font-size: 0.85rem;
        margin-bottom: 1.25rem;
    }

    .btn-login {
        width: 100%;
        padding: 11px;
        background: #4a90e2;
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 0.95rem;
        font-weight: 500;
        cursor: pointer;
        transition: background 0.2s, transform 0.1s;
        margin-top: 0.5rem;
    }

        .btn-login:hover {
            background: #357abd;
        }

        .btn-login:active {
            transform: scale(0.98);
        }

    @@media (max-width: 480px) {
        .login-body {
            padding: 1.5rem;
        }

        .login-header {
            padding: 1.5rem 1.5rem 1.25rem;
        }
    }
</style>

<div class="login-wrapper">
    <div class="login-card">
        <div class="login-header">
            <div class="login-icon">👤</div>
            <h2>Kullanıcı Girişi</h2>
            <p>Hesabınıza erişin</p>
        </div>
        <div class="login-body">
            @if (!string.IsNullOrEmpty(mymarkup))
            {
                <div class="error-message">@mymarkup</div>
            }
            <div class="form-group">
                <label for="username">E-posta Adresi</label>
                <input id="username" type="text" placeholder="ornek@sirket.com"
                       @bind="model.Username" @onkeypress="OnKeyPress" />
            </div>
            <div class="form-group">
                <label for="password">Şifre</label>
                <input id="password" type="password" placeholder="••••••••"
                       @bind="model.Password" @onkeypress="OnKeyPress" />
            </div>
            <button class="btn-login" @onclick="entryClick">Giriş Yap</button>
        </div>
    </div>
</div>

@code {
    private string? mymarkup;
    private Model model = new();

    [Parameter]
    public string? returnUrl { get; set; }

    [CascadingParameter]
    private Task<AuthenticationState>? authenticationState { get; set; }

    private class Model
    {
        public string Username { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }

    private async Task OnKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await entryClick();
    }

    private async Task entryClick()
    {
        await Authenticate();
    }

    private async Task Authenticate()
    {
        mymarkup = null;
        Entity.User user = await _userManager.GetUser(model.Username, model.Password);
        if (user == null)
        {
            mymarkup = "Hatalı kullanıcı adı veya şifre.";
            _logger.LogCritical($"Failed login attempt for user {model.Username}");
            return;
        }
        List<UserRole> roles = _userRoleManager.GetAll(user.Id).Result;
        string[] roleNames = roles.Select(r => r.Role.RoleName).ToArray();
        var customAuthStateProvider = (CustomAuthenticationStateProvider)authStateProvider;
        await customAuthStateProvider.UpdateAuthenticationState(new UserSession
            {
                UserName = user.Username,
                Role = roleNames,
                UserId = user.Id
            });
        _logger.LogInformation($"User {user.Username} logged in successfully");
        navManager.NavigateTo($"/{returnUrl ?? ""}", true);
    }
}