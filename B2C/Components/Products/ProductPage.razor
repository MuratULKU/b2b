                <div class="big-preview">
                    <img src="@selectedImage" alt="Büyük Görsel" />
                </div>

                <!-- Küçük Thumbnails -->
                <div class="thumbnail-list">
                    @foreach (var url in imageUrls)
                    {
                        <img src="@url" class="thumb @(url == selectedImage ? "active" : "")"
                             @onclick="() => SelectImage(url)" />
                    }
                </div>
            </div>
        } 
