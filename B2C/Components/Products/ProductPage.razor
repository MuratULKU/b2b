<style>
    .preview-container {
    display: flex;
    flex-direction: column;
    align-items: center;
}

.big-preview img {
    width: 400px;
    height: auto;
    margin-bottom: 10px;
    border: 2px solid #ccc;
    border-radius: 8px;
}

.thumbnail-list {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: center;
}

.thumbnail-list .thumb {
    width: 80px;
    height: 60px;
    object-fit: cover;
    cursor: pointer;
    border: 2px solid transparent;
    border-radius: 6px;
    transition: 0.2s;
}

.thumbnail-list .thumb:hover {
    border-color: #666;
}

.thumbnail-list .thumb.active {
    border-color: #007bff;
}

</style>
<div class="row">
    <div class="col-sm-6">
        <InputFile OnChange="HandleSelectedFiles" multiple />
        @if (imageUrls?.Count > 0)
        {
            <div class="preview-container">
